# Open API key shared by providers
OPEN_API_KEY=

# Shared provider URLs
# OPEN_API_URL=

# Stage providers
OCR_PROVIDER=openapi
EMBEDDING_PROVIDER=openapi
LLM_PROVIDER=openapi

# OCR settings
OCR_API_URL=https://api.openai.com/v1/responses
OCR_API_MODEL=gpt-4.1-mini
# OCR_TEST=true
# OCR_TEST_TEXT=
# OCR_API_KEY=

# Embedding settings
EMBEDDING_API_URL=
EMBEDDING_MODEL=
# EMBEDDING_API_KEY=

# LLM settings
LLM_API_URL=
LLM_MODEL=
# LLM_API_KEY=

# Console encoding
# Helps avoid broken Korean logs in Windows PowerShell / VSCode terminal.
PYTHONUTF8=1
PYTHONIOENCODING=utf-8

# PostgreSQL settings
# Prefer DATABASE_URL if you want a single DSN string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/job_post

# Optional split settings used when DATABASE_URL is not provided.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=job_post
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SSLMODE=disable
